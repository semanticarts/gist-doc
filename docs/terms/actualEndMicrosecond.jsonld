[
  {
    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/actualEndMicrosecond",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: The actual time that something ended, expressed as a system time used for timestamps."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EXAMPLE: '2021-06-01T08:03:27.12324-6:00'^^xsd:dateTime"
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: A system time will be as precise as the system can supply, typically at least milliseconds, sometimes microseconds. The convention for timestamps, such as recording a transaction, is to specify just the end point; the start time is rarely needed."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "actual end microsecond"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://w3id.org/semanticarts/ns/ontology/gist/actualEndDateTime"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "The actual time that something ended, expressed as a system time used for timestamps."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "'2021-06-01T08:03:27.12324-6:00'^^xsd:dateTime"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "actual end microsecond"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "A system time will be as precise as the system can supply, typically at least milliseconds, sometimes microseconds. The convention for timestamps, such as recording a transaction, is to specify just the end point; the start time is rarely needed."
      }
    ]
  }
]
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: Relates something to a content object that uniquely identifies it."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: This is like a URI: a thing can have more than one ID, but each ID can refer to only one thing. Note that it is possible to have two IDs with the same text that refer to different things."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [

    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: Relates an aspect to another aspect that is a subtracted component of it."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EXAMPLE: In the equation 'profit = revenue - expenses', revenue is an addend and expenses is a subtrahend."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: Commonly used with financial metrics."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [

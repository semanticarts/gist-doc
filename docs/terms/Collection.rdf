<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF xmlns:gist="https://w3id.org/semanticarts/ns/ontology/gist/" xmlns:owl="http://www.w3.org/2002/07/owl#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:skos="http://www.w3.org/2004/02/skos/core#">
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Collection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A grouping of things.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A jury is a group of people; a financial ledger is a collection of transaction entries; a route is an (ordered) collection of segments.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Individuals are placed in the collection using the gist:isMemberOf property. Collections typically are created because the members are functionally connected in some way. This definition allows a collection to have zero members.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Collection</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Composite" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A grouping of things.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A jury is a group of people; a financial ledger is a collection of transaction entries; a route is an (ordered) collection of segments.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Collection</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Individuals are placed in the collection using the gist:isMemberOf property. Collections typically are created because the members are functionally connected in some way. This definition allows a collection to have zero members.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/ControlledVocabulary">
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Collection" />
    <owl:equivalentClass rdf:nodeID="b79dc7b85023cdd06" />

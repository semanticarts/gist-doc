    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/isMadeUpOf",
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/semanticarts/ns/ontology/gist/PhysicalSubstance"
      }

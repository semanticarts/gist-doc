  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/GeoPoint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: An individual point on or above the Earth's surface, identified by latitude, longitude and altitude. Altitude is the distance measured from sea level. If altitude is missing, the point is assumed to be at the Earth's surface. These points are described using decimal latitude/longitude.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Geographic Point</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/GeoLocation" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/IntellectualProperty" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Intention" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Language" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Magnitude" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Organization" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/PhysicalIdentifiableItem" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/PhysicalSubstance" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/UnitOfMeasure" />
    <owl:equivalentClass rdf:nodeID="be3fe5313a648eeb4" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An individual point on or above the Earth's surface, identified by latitude, longitude and altitude. Altitude is the distance measured from sea level. If altitude is missing, the point is assumed to be at the Earth's surface. These points are described using decimal latitude/longitude.</skos:definition>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Geographic Point</skos:prefLabel>
  </rdf:Description>

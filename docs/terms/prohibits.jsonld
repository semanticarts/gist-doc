[
  {
    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/prevents",
    "http://www.w3.org/2002/07/owl#equivalentProperty": [
      {
        "@id": "https://w3id.org/semanticarts/ns/ontology/gist/prohibits"
      }
    ],
    "https://w3id.org/semanticarts/ns/ontology/gist/isSupersededBy": [
      {
        "@id": "https://w3id.org/semanticarts/ns/ontology/gist/prohibits"
      }
    ]
  },
  {
    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/prohibits",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: Relates an intention to a behavior that it forbids or seeks to prevent."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EXAMPLE: A city ordinance prohibits jaywalking."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EXAMPLE: Private property laws prohibit someone from entering private land marked with a 'No Trespassing' sign."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: A behavior can be prohibited without being prevented. For example, a speed limit may prohibit driving faster than a stated speed but does not always succeed in preventing drivers from exceeding that speed."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/semanticarts/ns/ontology/gist/Intention"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "prohibits"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/semanticarts/ns/ontology/gist/Behavior"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Relates an intention to a behavior that it forbids or seeks to prevent."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "A city ordinance prohibits jaywalking."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Private property laws prohibit someone from entering private land marked with a 'No Trespassing' sign."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "prohibits"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "A behavior can be prohibited without being prevented. For example, a speed limit may prohibit driving faster than a stated speed but does not always succeed in preventing drivers from exceeding that speed."
      }
    ]
  }

<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF xmlns:gist="https://w3id.org/semanticarts/ns/ontology/gist/" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:skos="http://www.w3.org/2004/02/skos/core#">
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/linksTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Relates a network link to its destination network node. Unlike the superproperty, this represents a directed connection.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">links to</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/links" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates a network link to its destination network node. Unlike the superproperty, this represents a directed connection.</skos:definition>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">links to</skos:prefLabel>
    <gist:domainIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/NetworkLink" />
    <gist:rangeIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/NetworkNode" />
  </rdf:Description>
</rdf:RDF>

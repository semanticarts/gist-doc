    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">owns</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The ultimate form of ownership is the right to destroy.</skos:scopeNote>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">There is a long list of potential range classes.</skos:scopeNote>

  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/MediaType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A digitized type that computer applications can recognize.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: application/sparql-results+xml</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: The unique text for an IANA media type is the concatenation of the 'Type name', a slash '/', and the 'Subtype name' as provided on the page displayed when you resolve the URI of the media type.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Media Type</rdfs:label>
    <rdfs:seeAlso rdf:resource="https://www.iana.org/assignments/media-types/media-types.xhtml" />
    <rdfs:subClassOf rdf:nodeID="b2c565a0344dcf56b" />
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Category" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A digitized type that computer applications can recognize.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">application/sparql-results+xml</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Media Type</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The unique text for an IANA media type is the concatenation of the 'Type name', a slash '/', and the 'Subtype name' as provided on the page displayed when you resolve the URI of the media type.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/uniqueText">
    <gist:domainIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/MediaType" />
  </rdf:Description>

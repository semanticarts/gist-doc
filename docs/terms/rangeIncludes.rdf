<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:skos="http://www.w3.org/2004/02/skos/core#">
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/rangeIncludes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Relates a property to a class that is an expected type of its values.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: The range of the property gist:isCategorizedBy includes gist:Category.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: There may be multiple rangeIncludes assertions on a single property.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: This property is used to guide the ontology user; like all annotation properties, it does not play a role in inference.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">range includes</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates a property to a class that is an expected type of its values.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The range of the property gist:isCategorizedBy includes gist:Category.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">range includes</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">There may be multiple rangeIncludes assertions on a single property.</skos:scopeNote>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property is used to guide the ontology user; like all annotation properties, it does not play a role in inference.</skos:scopeNote>
  </rdf:Description>
</rdf:RDF>

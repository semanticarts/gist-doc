  },
  {
    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/exponentOfMeter",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: The exponent of meter in a product of powers of base units."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EXAMPLE: In the equation '1 microgram per milliliter = 0.001 x kilogram per meterCubed'\r\n\r\n\t\tthe conversion factor for microgram per milliliter is 0.001\r\n\t\tthe exponent of kilogram is 1\r\n\t\tthe exponent of meter is -3\r\n\t\tall other exponents are zero\r\n\r\n\t\tEvery member of a unit group containing microgram per milliliter must be a multiple of kilogram per meterCubed."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "_:b298c1caf1a4f5380"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "exponent of meter"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "The exponent of meter in a product of powers of base units."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "In the equation '1 microgram per milliliter = 0.001 x kilogram per meterCubed'\r\n\r\n\t\tthe conversion factor for microgram per milliliter is 0.001\r\n\t\tthe exponent of kilogram is 1\r\n\t\tthe exponent of meter is -3\r\n\t\tall other exponents are zero\r\n\r\n\t\tEvery member of a unit group containing microgram per milliliter must be a multiple of kilogram per meterCubed."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "exponent of meter"

<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF xmlns:owl="http://www.w3.org/2002/07/owl#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:skos="http://www.w3.org/2004/02/skos/core#">
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/ContingentObligation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: An obligation that is not yet firm. There is some contingent event whose occurrence will cause the obligation to become firm.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: A contingent obligation might have a getter counterparty (as in the case of insurance); but it might not (as in the case of an offer).</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contingent Obligation</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Commitment" />
    <owl:equivalentClass rdf:nodeID="bdaf499a6078fa7c2" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An obligation that is not yet firm. There is some contingent event whose occurrence will cause the obligation to become firm.</skos:definition>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contingent Obligation</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A contingent obligation might have a getter counterparty (as in the case of insurance); but it might not (as in the case of an offer).</skos:scopeNote>
  </rdf:Description>

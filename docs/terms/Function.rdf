<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:skos="http://www.w3.org/2004/02/skos/core#">
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Function">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: The activity that a human-made item is intended to perform.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: Transmit electricity, provide ballast, control ambient temperature.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Function</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Intention" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The activity that a human-made item is intended to perform.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transmit electricity, provide ballast, control ambient temperature.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Function</skos:prefLabel>
  </rdf:Description>
</rdf:RDF>

  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/isFirstMemberOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty" />
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Relates the first member of an ordered collection to the collection.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Given the Open World Assumption, the absence of a predecessor does not entail that an ordered member is the first member of an ordered collection. This property is used to explicitly indicate the first member. Since ordered collections need not be strictly ordered, there can be more than one first member.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/OrderedMember" />
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is first member of</rdfs:label>
    <rdfs:range rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/OrderedCollection" />
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/isMemberOf" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates the first member of an ordered collection to the collection.</skos:definition>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is first member of</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Given the Open World Assumption, the absence of a predecessor does not entail that an ordered member is the first member of an ordered collection. This property is used to explicitly indicate the first member. Since ordered collections need not be strictly ordered, there can be more than one first member.</skos:scopeNote>
  </rdf:Description>

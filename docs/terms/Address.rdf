  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Address">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A reference to a place (real or virtual) that can be located by some routing algorithm and where messages or things can be sent or received.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A PO Box, a URL to a PDF file.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Address</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Content" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A reference to a place (real or virtual) that can be located by some routing algorithm and where messages or things can be sent or received.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A PO Box, a URL to a PDF file.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Address</skos:prefLabel>
  </rdf:Description>

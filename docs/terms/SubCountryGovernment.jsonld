  {
    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/CountryGovernment",
    "http://www.w3.org/2002/07/owl#disjointWith": [
      {
        "@id": "https://w3id.org/semanticarts/ns/ontology/gist/SubCountryGovernment"
      }
    ]
  },
  {
    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/SubCountryGovernment",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: The government of a governed geographic region other than a country which is under the direct or indirect control of a country government."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: Note that the predicate gist:isGovernedBy is used both for the relationship a governed geographic region has to its government and for the relationship a sub-region government has to the government of the larger region."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: There are many types of sub-regions of a country and the governments thereof (as well as different terms, like 'province' and 'state,' which refer to essentially the same type of thing). We should not automatically assume 'state,' 'county,' and 'city.' Subclasses or categories can be defined if greater specificity is needed."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: This class applies only to organizations governing geographic regions. Regulatory and bureaucratic organizations are members of the more generic gist:GovernmentOrganization class."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Sub-Country Government"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/semanticarts/ns/ontology/gist/GovernmentOrganization"
      }
    ],
    "http://www.w3.org/2002/07/owl#equivalentClass": [
      {
        "@id": "_:b300fe1a7b9bd7cbc"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "The government of a governed geographic region other than a country which is under the direct or indirect control of a country government."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Sub-Country Government"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Note that the predicate gist:isGovernedBy is used both for the relationship a governed geographic region has to its government and for the relationship a sub-region government has to the government of the larger region."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "There are many types of sub-regions of a country and the governments thereof (as well as different terms, like 'province' and 'state,' which refer to essentially the same type of thing). We should not automatically assume 'state,' 'county,' and 'city.' Subclasses or categories can be defined if greater specificity is needed."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "This class applies only to organizations governing geographic regions. Regulatory and bureaucratic organizations are members of the more generic gist:GovernmentOrganization class."
      }
    ]
  }

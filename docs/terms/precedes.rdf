<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:skos="http://www.w3.org/2004/02/skos/core#">
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/precedes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A generic ordering relation indicating that the subject comes before the object.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: The less-than symbol is often used to represent this relation.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: This is the transitive version of gist:precedesDirectly.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Typically this predicate would be used asymmetrically and irreflexively, but the ontology does not formalize this.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">precedes</rdfs:label>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A generic ordering relation indicating that the subject comes before the object.</skos:definition>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">precedes</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The less-than symbol is often used to represent this relation.</skos:scopeNote>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This is the transitive version of gist:precedesDirectly.</skos:scopeNote>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Typically this predicate would be used asymmetrically and irreflexively, but the ontology does not formalize this.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/precedesDirectly">
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/precedes" />
  </rdf:Description>
</rdf:RDF>

[
  {
    "@id": "_:bee053dac94d643b7",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2002/07/owl#unionOf": [
      {
        "@list": [
          {
            "@id": "https://w3id.org/semanticarts/ns/ontology/gist/UnitGroup"
          },
          {
            "@id": "https://w3id.org/semanticarts/ns/ontology/gist/UnitOfMeasure"
          }
        ]
      }
    ]
  },
  {
    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/exponentOfNumber",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: The exponent of number in a product of powers of base units."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EXAMPLE: In the equation '1 beat per minute = 0.016667 x number per second'\r\n\r\n\t\tthe conversion factor for beat per minute is 0.016667\r\n\t\tthe exponent of number is 1\r\n\t\tthe exponent of second is -1\r\n\t\tall other exponents are zero\r\n\r\n\t\tEvery member of a unit group containing beat per minute must be a multiple of number per second."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: Use when the unit of measure involves a count or other number."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "_:bee053dac94d643b7"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "exponent of number"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "The exponent of number in a product of powers of base units."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "In the equation '1 beat per minute = 0.016667 x number per second'\r\n\r\n\t\tthe conversion factor for beat per minute is 0.016667\r\n\t\tthe exponent of number is 1\r\n\t\tthe exponent of second is -1\r\n\t\tall other exponents are zero\r\n\r\n\t\tEvery member of a unit group containing beat per minute must be a multiple of number per second."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "exponent of number"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Use when the unit of measure involves a count or other number."
      }
    ]
  }

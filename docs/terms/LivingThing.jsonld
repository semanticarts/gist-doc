    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: Something that is currently, or at some point in time was, alive."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EXAMPLE: A cat, a mushroom, a tree."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EXAMPLE: Negative examples: fictional life forms such as unicorns or Mickey Mouse."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: Not all life forms have exactly two parents, so the restriction only specifies a minimum of one."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [

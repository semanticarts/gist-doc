    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: A generic ordering relation indicating that the subject comes before the object."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: The less-than symbol is often used to represent this relation."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: This is the transitive version of gist:precedesDirectly."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: Typically this predicate would be used asymmetrically and irreflexively, but the ontology does not formalize this."
      }
    ],

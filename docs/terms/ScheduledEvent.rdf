  <rdf:Description rdf:nodeID="b743401dbe12a2501">
    <rdf:first rdf:nodeID="b976b3842ce635d94" />
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil" />
  </rdf:Description>
  <rdf:Description rdf:nodeID="b976b3842ce635d94">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction" />
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/plannedStartDateTime" />

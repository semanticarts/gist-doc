  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/DegreeOfCommitment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: The difficulty of reversing a commitment.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A car rental typically has a lower degree of commitment than an airfare reservation.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Degree Of Commitment</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Category" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The difficulty of reversing a commitment.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A car rental typically has a lower degree of commitment than an airfare reservation.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Degree Of Commitment</skos:prefLabel>
  </rdf:Description>

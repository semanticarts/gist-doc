  {
    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/Composite",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: Something which is made up of various parts or elements that are independently identifiable."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EXAMPLE: A library (collection of books); a network of pipes and valves; a computer network of routers and computers."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: Some composites, like systems, networks, and ordered collections, have internal organization, while others, such as unordered collections, typically do not."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: This class is not disjoint with gist:Component, because a composite can itself be a component of a larger composite."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: This is an abstract class that will not be directly instantiated."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Composite"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Something which is made up of various parts or elements that are independently identifiable."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "A library (collection of books); a network of pipes and valves; a computer network of routers and computers."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Composite"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Some composites, like systems, networks, and ordered collections, have internal organization, while others, such as unordered collections, typically do not."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "This class is not disjoint with gist:Component, because a composite can itself be a component of a larger composite."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "This is an abstract class that will not be directly instantiated."
      }
    ]

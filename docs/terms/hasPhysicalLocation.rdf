  <rdf:Description rdf:nodeID="baac7eba307a3ddfe">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction" />
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/hasPhysicalLocation" />
    <owl:someValuesFrom rdf:nodeID="b6a771a60999ef60c" />

    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SSN for a person; serial number for a product; employee ID for a person.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ID</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Used in conjunction with gist:isIdentifiedBy.</skos:scopeNote>

    <rdfs:range rdf:nodeID="b541c02a3037d8d8b" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates something to its destination place.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A letter has an address indicating its destination; a segment of a delivery route terminates at a delivery location; a trail terminates at an intersection with another trail.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">goes to place</skos:prefLabel>

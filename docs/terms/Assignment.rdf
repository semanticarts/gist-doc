<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF xmlns:gist="https://w3id.org/semanticarts/ns/ontology/gist/" xmlns:owl="http://www.w3.org/2002/07/owl#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:skos="http://www.w3.org/2004/02/skos/core#">
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Assignment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A temporal relationship between an assignee, the thing assigned, and the resource that made the assignment.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: An employee is assigned to a task by a supervisor. A person is assigned to a position.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Based on the Open World Assumption, the assigner may not be asserted or known.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: For some assignments, such as the assignment of a person to a task, it may seem equally correct in ordinary speech to say it is an assignment of a task to a person. Since gist:isAssignmentTo and gist:isAssignmentOf have no formal domains or ranges, the choice of which predicate to use for which is left as an implementation decision. Consistency is a key consideration.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Assignment</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/TemporalRelation" />
    <owl:equivalentClass rdf:nodeID="b24ffea1d4221e5d2" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A temporal relationship between an assignee, the thing assigned, and the resource that made the assignment.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An employee is assigned to a task by a supervisor. A person is assigned to a position.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Assignment</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Based on the Open World Assumption, the assigner may not be asserted or known.</skos:scopeNote>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">For some assignments, such as the assignment of a person to a task, it may seem equally correct in ordinary speech to say it is an assignment of a task to a person. Since gist:isAssignmentTo and gist:isAssignmentOf have no formal domains or ranges, the choice of which predicate to use for which is left as an implementation decision. Consistency is a key consideration.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/isAssignmentOf">
    <gist:domainIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Assignment" />
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/isAssignmentTo">
    <gist:domainIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Assignment" />
  </rdf:Description>

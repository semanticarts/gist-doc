  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Text">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Content expressed as a written sequence of characters.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: Negative example: photographs or scans of text are not text. These instead depict a subject, which happens to be text.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Text is expressed in a language (human or computer) and may but need not specify an encoding.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Text</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/ContentExpression" />
    <owl:equivalentClass rdf:nodeID="b93f1948f4bfd8258" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Content expressed as a written sequence of characters.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Negative example: photographs or scans of text are not text. These instead depict a subject, which happens to be text.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Text</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Text is expressed in a language (human or computer) and may but need not specify an encoding.</skos:scopeNote>
  </rdf:Description>

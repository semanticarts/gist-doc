        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Content encoded in a specific format, but existing as data independent of any particular physical medium."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "A document in PDF format; an image in JPEG format."
      }
    ],

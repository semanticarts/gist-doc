<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF xmlns:owl="http://www.w3.org/2002/07/owl#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:skos="http://www.w3.org/2004/02/skos/core#">
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/exponentOfOther">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Indicates whether a unit of measure can be expressed in terms of the standard exponents (as shown in the examples).</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: Decibel, pH, and octave are units of measure that are logarithmic. Their unit groups have exponent of other = 1.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Set the value to 0 if the units of measure in the unit group can be expressed using the standard set of exponents (as in the examples).&#13;
&#13;
		Otherwise set the value to 1, which typically means the units of measure in the group use a logarithmic scale.</rdfs:comment>
    <rdfs:domain rdf:nodeID="b482663fdc6d31753" />
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">exponent of other</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indicates whether a unit of measure can be expressed in terms of the standard exponents (as shown in the examples).</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decibel, pH, and octave are units of measure that are logarithmic. Their unit groups have exponent of other = 1.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">exponent of other</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Set the value to 0 if the units of measure in the unit group can be expressed using the standard set of exponents (as in the examples).&#13;
&#13;
		Otherwise set the value to 1, which typically means the units of measure in the group use a logarithmic scale.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:nodeID="b388a5c80f7b168be">
    <rdf:first rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/UnitGroup" />
    <rdf:rest rdf:nodeID="bda181dcd0d040cca" />
  </rdf:Description>
  <rdf:Description rdf:nodeID="b482663fdc6d31753">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <owl:unionOf rdf:nodeID="b388a5c80f7b168be" />
  </rdf:Description>
  <rdf:Description rdf:nodeID="bda181dcd0d040cca">
    <rdf:first rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/UnitOfMeasure" />
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil" />
  </rdf:Description>
</rdf:RDF>

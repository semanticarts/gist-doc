    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/ContingentObligation",
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/semanticarts/ns/ontology/gist/Commitment"
      }
    ],

  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/CountryGovernment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A government organization which asserts both sovereignty (i.e., it is not governed by some other government organization) and governance over an entity generally recognized as a country.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: While a country government may enter into treaties with other country governments, there are no governing relationships among the treaty members.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Country Government</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="b2455b81a45d8d233" />
    <rdfs:subClassOf rdf:nodeID="bbff8ffb23ee84e33" />
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/GovernmentOrganization" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/SubCountryGovernment" />
    <owl:equivalentClass rdf:nodeID="b5fa7d0f646b24b48" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A government organization which asserts both sovereignty (i.e., it is not governed by some other government organization) and governance over an entity generally recognized as a country.</skos:definition>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Country Government</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">While a country government may enter into treaties with other country governments, there are no governing relationships among the treaty members.</skos:scopeNote>
  </rdf:Description>

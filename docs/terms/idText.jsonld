[
  {
    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/idText",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: A text string that identifies an individual."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EXAMPLE: The id text for a car is '4Y1SL65848Z411439'; the id text for the HR department of some company is H31415."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: A common use case would be for preexisting internal company identifiers."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: Often, there will be just one identifying text string. More would be appropriate if the individual had different identifiers, such as employee number and social security number. A good way to model that would be to have functional subproperties of idText, such as departmentNumber."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: This property is an alternative to using the property gist:isIdentifiedBy in conjunction with instances of the class gist:ID."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "id text"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "A text string that identifies an individual."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "The id text for a car is '4Y1SL65848Z411439'; the id text for the HR department of some company is H31415."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "id text"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "A common use case would be for preexisting internal company identifiers."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Often, there will be just one identifying text string. More would be appropriate if the individual had different identifiers, such as employee number and social security number. A good way to model that would be to have functional subproperties of idText, such as departmentNumber."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "This property is an alternative to using the property gist:isIdentifiedBy in conjunction with instances of the class gist:ID."
      }
    ]
  }
]
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/NetworkLink">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: An abstract representation of the connection between two or more nodes in a network.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A network link may be physical, such as pipes, wired or wireless networks, but may also be a link in a non-physical network, such as organizational structures or social networks.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Each network link is connected to a network node via the property gist:links or one of its subproperties.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Network Link</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="b419791605f3bbfb5" />
    <rdfs:subClassOf rdf:nodeID="b9962d8ba57c5d603" />
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Component" />
    <owl:equivalentClass rdf:nodeID="b59650526cc8a09be" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An abstract representation of the connection between two or more nodes in a network.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A network link may be physical, such as pipes, wired or wireless networks, but may also be a link in a non-physical network, such as organizational structures or social networks.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Network Link</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Each network link is connected to a network node via the property gist:links or one of its subproperties.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/links">
    <gist:domainIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/NetworkLink" />

        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Building"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/semanticarts/ns/ontology/gist/Landmark"
      }
    ],
    "http://www.w3.org/2002/07/owl#deprecated": [

  {
    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/Component",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: Something that, while having an independent existence, is inherently part of or designed to be part of a larger entity, such as a system or network."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: A component may be designed or intended as part of a whole without actually being so; e.g., a car steering wheel that is not installed in any car."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: Many things are in a trivial sense a part of a larger thing, but are not considered components because they are not inherently part of that larger thing. For example, while a book may be part of a library (a collection of books), it is not inherently so, and thus is not a component. A playing card, on the other hand, could be considered a component in (member of) a deck of cards. This may be use case-dependent; e.g., car parts might be modeled as components in an automobile manufacturing context but not in a retail auto parts store."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: Physical substances, such as ingredients in a cake batter, do not meet the independent existence criterion, so are not components."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: This class is not disjoint with gist:Composite, because a component may itself break down into smaller components."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: This is an abstract class that is not directly instantiated. Users will define subclasses that are meaningful to their domain of interest."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Component"
      }
    ],
    "http://www.w3.org/2002/07/owl#disjointWith": [
      {
        "@id": "https://w3id.org/semanticarts/ns/ontology/gist/PhysicalSubstance"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Something that, while having an independent existence, is inherently part of or designed to be part of a larger entity, such as a system or network."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Component"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "A component may be designed or intended as part of a whole without actually being so; e.g., a car steering wheel that is not installed in any car."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Many things are in a trivial sense a part of a larger thing, but are not considered components because they are not inherently part of that larger thing. For example, while a book may be part of a library (a collection of books), it is not inherently so, and thus is not a component. A playing card, on the other hand, could be considered a component in (member of) a deck of cards. This may be use case-dependent; e.g., car parts might be modeled as components in an automobile manufacturing context but not in a retail auto parts store."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Physical substances, such as ingredients in a cake batter, do not meet the independent existence criterion, so are not components."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "This class is not disjoint with gist:Composite, because a component may itself break down into smaller components."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "This is an abstract class that is not directly instantiated. Users will define subclasses that are meaningful to their domain of interest."
      }
    ]
  },

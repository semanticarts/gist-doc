    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: A composite consisting of nodes connected by links."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EXAMPLE: A physical network could include connected computers or routers, whereas a social network would consist of related person or organization members (or their proxies, such as accounts)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [

    <rdfs:range rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/UnitOfMeasure" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates a magnitude to its unit of measure.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The magnitude 87 inches of height has unit of measure inches.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has unit of measure</skos:prefLabel>

  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/System">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A composite made up of interacting or interdependent components that together operate as a whole.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A manufacturing system, a storm system.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: May be used to refer to either man-made or natural systems.</rdfs:comment>

  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Organization">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A structured entity formed to achieve specific goals, typically involving members with defined roles.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: Legal entities like companies; non-legal entities like clubs, committees, or departments.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Not all organizations have members, e.g. shell companies.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: While typically the members of organizations are people, in some cases they are other organizations; e.g., the members of the United Nations are country governments.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Organization</rdfs:label>
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/PhysicalIdentifiableItem" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/PhysicalSubstance" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/SchemaMetaData" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/UnitOfMeasure" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A structured entity formed to achieve specific goals, typically involving members with defined roles.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal entities like companies; non-legal entities like clubs, committees, or departments.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Organization</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not all organizations have members, e.g. shell companies.</skos:scopeNote>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">While typically the members of organizations are people, in some cases they are other organizations; e.g., the members of the United Nations are country governments.</skos:scopeNote>
  </rdf:Description>

  {
    "@id": "https://w3id.org/semanticarts/ns/ontology/gist/Agreement",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "DEFINITION: A mutually understood arrangement in which two or more parties make commitments to one another."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "EXAMPLE: A gym membership is an agreement in which the member commits to paying the gym a certain price and the gym commits to allowing access to their facilities."
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "NOTE: While an agreement has two or more parties, and contains commitments which bind those parties, it will not always be necessary to instantiate each individual commitment."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Agreement"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/semanticarts/ns/ontology/gist/Intention"
      }
    ],
    "http://www.w3.org/2002/07/owl#equivalentClass": [
      {
        "@id": "_:bc87a3bb4e2743695"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "A mutually understood arrangement in which two or more parties make commitments to one another."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "A gym membership is an agreement in which the member commits to paying the gym a certain price and the gym commits to allowing access to their facilities."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "Agreement"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "While an agreement has two or more parties, and contains commitments which bind those parties, it will not always be necessary to instantiate each individual commitment."

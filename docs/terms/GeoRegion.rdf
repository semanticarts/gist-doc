<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF xmlns:owl="http://www.w3.org/2002/07/owl#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:skos="http://www.w3.org/2004/02/skos/core#">
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Content">
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/GeoRegion" />
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/GeoRegion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A bounded region (or set of regions) on the surface of the Earth.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: The bounded shape that defines the region occupied by Crater Lake; the bounded area known as the contiguous USA.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: A geographic region could be non-contiguous; e.g., the region governed by the US federal government is the contiguous area of the lower 48 states plus Alaska, Hawaii, and overseas territories. Child classes in lower ontologies can make this distinction.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Geographic Region</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="b24d3c8ed1e94e099" />
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/GeoLocation" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/IntellectualProperty" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Intention" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Language" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Magnitude" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Organization" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/PhysicalIdentifiableItem" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/PhysicalSubstance" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Template" />
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/UnitOfMeasure" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A bounded region (or set of regions) on the surface of the Earth.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The bounded shape that defines the region occupied by Crater Lake; the bounded area known as the contiguous USA.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Geographic Region</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A geographic region could be non-contiguous; e.g., the region governed by the US federal government is the contiguous area of the lower 48 states plus Alaska, Hawaii, and overseas territories. Child classes in lower ontologies can make this distinction.</skos:scopeNote>
  </rdf:Description>

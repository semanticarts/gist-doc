<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF xmlns:gist="https://w3id.org/semanticarts/ns/ontology/gist/" xmlns:owl="http://www.w3.org/2002/07/owl#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:skos="http://www.w3.org/2004/02/skos/core#">
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/prevents">
    <owl:equivalentProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/prohibits" />
    <gist:isSupersededBy rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/prohibits" />
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/prohibits">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Relates an intention to a behavior that it forbids or seeks to prevent.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A city ordinance prohibits jaywalking.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: Private property laws prohibit someone from entering private land marked with a 'No Trespassing' sign.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: A behavior can be prohibited without being prevented. For example, a speed limit may prohibit driving faster than a stated speed but does not always succeed in preventing drivers from exceeding that speed.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Intention" />
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">prohibits</rdfs:label>
    <rdfs:range rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Behavior" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates an intention to a behavior that it forbids or seeks to prevent.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A city ordinance prohibits jaywalking.</skos:example>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Private property laws prohibit someone from entering private land marked with a 'No Trespassing' sign.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">prohibits</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A behavior can be prohibited without being prevented. For example, a speed limit may prohibit driving faster than a stated speed but does not always succeed in preventing drivers from exceeding that speed.</skos:scopeNote>
  </rdf:Description>
</rdf:RDF>

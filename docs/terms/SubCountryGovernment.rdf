    <owl:onProperty rdf:nodeID="ba62aeb6a3de270f2" />
    <owl:someValuesFrom rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/GeoRegion" />
  </rdf:Description>
  <rdf:Description rdf:nodeID="b5e86dc3ec2f4ef7a">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction" />
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/isGovernedBy" />
    <owl:someValuesFrom rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/CountryGovernment" />
  </rdf:Description>

  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/TaskTemplate">
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Template" />
    <owl:equivalentClass rdf:nodeID="bd24d260c1ca7f037" />
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Template">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Something used to make objects in its own image.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A die in manufacturing is used to make stamped parts; a form provides a structure and fields to be filled in; a cookie cutter is a template for cookies.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Use gist:isBasedOn to link the object made from the template back to the template.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0" />
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Template</rdfs:label>
    <owl:disjointWith rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/UnitOfMeasure" />
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Something used to make objects in its own image.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A die in manufacturing is used to make stamped parts; a form provides a structure and fields to be filled in; a cookie cutter is a template for cookies.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Template</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use gist:isBasedOn to link the object made from the template back to the template.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:nodeID="b661cf8a8349c529e">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction" />
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/hasGoal" />
    <owl:someValuesFrom rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Intention" />
  </rdf:Description>
  <rdf:Description rdf:nodeID="ba91e7d7eec475f7c">

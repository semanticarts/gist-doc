    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "An address referring to a locatable virtual place that does not physically exist but is made by software or electronics to appear to do so."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "A file system path, website URL, IP address, email address, mobile or landline telephone number."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [

    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The unique string value of some content object, to be used when there is no possibility of having more than one value.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The unique string for a vehicle identification number.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">unique text</skos:prefLabel>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Note that the uniqueness only goes in one direction: a product catalog number might also be an employee ID.</skos:scopeNote>
